    {
      "cell_type": "code",
      "source": [
        "n_hidden=32 #hidden layer neurons\n",
        "W1=torch.randn(block_size*dim,n_hidden,generator=g) #we want n_hidden columns (visualise 100 neurons in a neural network in a column) and and since we have emb_cat having 1638 x 30 or 30 inputs for each row we need 30 x ... for W1 so matrix multiplication works\n",
        "b1=torch.randn(n_hidden,generator=g)\n",
        "W2=torch.randn(n_hidden,n,generator=g) #n_hiddenx28 cuz we want 27 neurons each giving us a score of the possiblility that the next character is one of the 27 possible characters\n",
        "b2=torch.rand(n,generator=g)\n",
        "print(W1.shape)\n",
        "print(b1.shape)\n",
        "print(W2.shape)\n",
        "print(b2.shape)\n",
        "parameters=[C,W1,b1,W2,b2]\n"
      ],
