    {
      "cell_type": "code",
      "source": [
        "import re\n",
        "import requests\n",
        "from bs4 import BeautifulSoup\n",
        "\n",
        "url = \"https://pokemondb.net/pokedex/national\"\n",
        "html = requests.get(url).text\n",
        "soup = BeautifulSoup(html, \"html.parser\")\n",
        "\n",
        "pokemon_names = []\n",
        "\n",
        "for a in soup.select(\"a.ent-name\"):\n",
        "    name = a.text.lower()\n",
        "\n",
        "    # keep only letters a-z\n",
        "    name = re.sub(r'[^a-z]', '', name)\n",
        "\n",
        "    if name:\n",
        "        pokemon_names.append(name)\n",
        "\n",
        "# remove duplicates while preserving order\n",
        "pokemon_names = list(dict.fromkeys(pokemon_names))\n"
      ],
      "metadata": {
        "id": "G2V2gBMnibTj"
      },
      "execution_count": 25,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "chars=sorted(list(set(''.join(pokemon_names)))) #creating a set of all the characters in my dataset which will be a-z\n",
        "stoi={s:i+1 for i,s in enumerate(chars)} #stoi is a dictionary that stores the char as key and its corressponding value, eg. a:1,b:2,c:3,etc\n",
        "stoi['.']=0\n",
        "itos={i:s for s,i in stoi.items()} #itos is like stoi but key and values are interchanged, 1:a,2:b,etc\n",
        "\n",
        "import random\n",
        "random.seed(42)\n",
        "random.shuffle(pokemon_names)\n",
        "\n",
        "\n",
        "n1 = int(0.8*len(pokemon_names))\n",
        "n2 = int(0.9*len(pokemon_names))\n",
        "block_size=3\n",
        "def build_dataset(pokemon_names):\n",
        "  X,Y=[],[]\n",
        "  for w in pokemon_names:\n",
        "      context=[0]*block_size\n",
        "      for ch in w+'.':\n",
        "          ix=stoi[ch]\n",
        "          X.append(context)\n",
        "          Y.append(ix)\n",
        "          context=context[1:]+[ix]\n",
        "  return torch.tensor(X),torch.tensor(Y)\n",
        "  X,Y=build_dataset(pokemon_names[:n1])\n",
        "#carrying this loop on till the end of \"lol\" well have X,Y like this:\n",
        "#ch = lol+\".\" = lol.\n",
        "#for l - ix=12, context=[0,0,0],X=[[0,0,0]] , Y=[12]\n",
        "#for o - ix=15, context=[0,0,12],X=[[0,0,0],[0,0,12]] , Y=[12,15]\n",
        "#for l - ix=12, context=[0,12,15],X=[[0,0,0],[0,0,12],[0,12,15]] , Y=[12,15,12]\n",
        "#for . - ix=0,context=[12,15,12],X=[[0,0,0],[0,0,12],[0,12,15],[12,15,12]] , Y=[12,15,12,0]\n",
        "#this is just used for every name to train the model about what would mostly come next if these 3 letters are together, it doesnt give the model a definitive answer as the model using sampling and probabiltity while generating names\n",
        "#creating tensors of x and y so that we can use pytorch to code and make our neural network\n",
        "Xtr, Ytr = build_dataset(pokemon_names[:n1])      # 80% train\n",
        "Xdev, Ydev = build_dataset(pokemon_names[n1:n2])  # 10% dev\n",
        "Xte, Yte = build_dataset(pokemon_names[n2:]) # 10% test\n",
        "print(Xtr.shape, Xdev.shape, Xte.shape)\n",
        "print(Ytr.shape, Ydev.shape, Yte.shape)\n"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "oAk-giOZW6ub",
