    {
      "cell_type": "code",
      "source": [
        "#putting it all together!\n",
        "import torch.nn.functional as F\n",
        "for p in parameters:\n",
        "    p.requires_grad = True #used for making sure gradient is tracked during back propogation\n",
        "lr=0.5 #how big of a step we should take while making the model learn\n",
        "steps=10000 #gradient descent will happen 10000 times to learn\n",
        "batch_size=32\n",
        "for i in range(steps):\n",
        "  ix=torch.randint(0,Xtr.shape[0],(batch_size,),generator=g) #takes 32 random rows from 0 to 1638 possible rows\n",
        "  emb=C[Xtr[ix]] #same as emb=C[ix] but for the 32 selected rows\n",
        "  emb_cat=torch.cat(torch.unbind(emb,1),1)\n",
        "  h=torch.tanh(emb_cat @ W1 + b1) # we use a tanh function to squash every output bw -1 and 1\n",
        "  logits = h @ W2 + b2\n",
        "  loss = F.cross_entropy(logits, Ytr[ix]) # A shortcut to calculate loss by making the logits from values to probabilites of that character occuring and comparing it with the correct answer or Y[ix]\n",
        "  '''\n",
        "  Another way you can do instead of cross_entropy\n",
        "  counts = logits.exp()\n",
        "  probs = counts / counts.sum(1, keepdim=True)\n",
        "  loss = -probs[torch.arange(batch_size), Y].log().mean()'''\n",
        "  lr = 0.1 if i < 6000 else 0.01 #changing the learning rate from 0.1 to 0.01 is called learning decay and is done because at the later stages of training a model we want a smaller learning rate so it learns more smoother not a large one\n",
        "  for p in parameters:\n",
        "    p.grad=None #you want to reset your gradient after each step not accumulate them\n",
        "  loss.backward() #performs backprop\n",
        "  for p in parameters:\n",
        "      p.data += -lr * p.grad #used to update data values based on gradient and learning rate after back propogation\n",
        "\n",
        "  if i % 1000 == 0:\n",
        "     with torch.no_grad():\n",
        "            emb_dev = C[Xdev]\n",
        "            h_dev = torch.tanh(emb_dev.view(emb_dev.shape[0], -1) @ W1 + b1)\n",
        "            logits_dev = h_dev @ W2 + b2\n",
        "            dev_loss = F.cross_entropy(logits_dev, Ydev)\n",
        "    #if train loss keeps dropping but dev loss stalls or rises, that's overfitting — the model is memorizing training names rather than learning general spelling patterns.\n",
        "     print(f\"step {i}: train {loss.item():.4f}  dev {dev_loss.item():.4f}\")\n"
      ],
