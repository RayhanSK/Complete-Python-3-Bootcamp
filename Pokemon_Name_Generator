            "torch.Size([7005, 3]) torch.Size([909, 3]) torch.Size([912, 3])\n",
            "torch.Size([7005]) torch.Size([909]) torch.Size([912])\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "n=len(stoi) #28\n",
        "dim=6 # we want each character like 'a' be a vector of dim dimensions like [0.1,0.5,0.64,...], if we only train it on one dimension like a=1 or b=2, we dont want the model to learn that b>a so we do this\n",
        "g=torch.Generator().manual_seed(2147483647) #we use a manual seed here to get the same output of g every single time we run any code related to g\n",
        "C=torch.randn((n,dim),generator=g) #C is a randomly allocated matrix of 28xdim where each 28 rows have 10 columns of random numbers\n",
        "emb=C[Xtr] #this basically creates emb of a matrix of shape 1638 x 3 x dim\n",
        "emb_cat=torch.cat(torch.unbind(emb,1),1) #this is simply just making the first row of emb from [1,2,3,4..],[5,6,7,8...] to [1,2,3,4,5,6,7,8..].\n",
        "\n",
        "print(emb.shape)\n",
        "print(emb_cat.shape) # 1638 x (3 times dim)\n"
      ],
      "metadata": {
